<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MarketPulse · Painel</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0d1117;--bg2:#161b27;--card:#1c2333;--card2:#242f45;--border:#293548;
  --green:#23d18b;--red:#f14c60;--gold:#f0b429;--blue:#58a6ff;--purple:#a371f7;--orange:#f78166;
  --text:#e6edf3;--sub:#cdd9e5;--muted:#8b949e;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:radial-gradient(ellipse at 20% 50%,rgba(35,209,139,.03) 0%,transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(88,166,255,.03) 0%,transparent 60%);pointer-events:none;z-index:0;}

/* ══ TOPBAR ═══════════════════════════════════════════════════════════════ */
.topbar{position:fixed;top:0;left:0;right:0;z-index:200;height:48px;background:rgba(13,17,23,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;gap:12px;}
.logo{font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;font-weight:800;letter-spacing:3px;color:#fff;display:flex;align-items:center;gap:8px;text-decoration:none;flex-shrink:0;}
.ld{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 10px var(--green);animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.6;transform:scale(.85);}}
.tsep{width:1px;height:18px;background:var(--border);flex-shrink:0;}
.bb{font-family:'Barlow Condensed',sans-serif;font-size:.8rem;font-weight:700;letter-spacing:3px;display:flex;align-items:center;gap:5px;flex-shrink:0;}
.bl{color:var(--green);}.vs{color:var(--muted);font-size:.65rem;}.br{color:var(--red);}
.top-idx{display:flex;gap:14px;align-items:center;font-family:'JetBrains Mono',monospace;font-size:.62rem;flex:1;overflow:hidden;}
.ti{display:flex;gap:4px;align-items:center;white-space:nowrap;}
.ti-n{color:var(--muted);}
.up{color:var(--green);} .down{color:var(--red);}
@keyframes fup{0%{color:#fff;text-shadow:0 0 10px var(--green);}100%{color:var(--green);text-shadow:none;}}
@keyframes fdn{0%{color:#fff;text-shadow:0 0 10px var(--red);}100%{color:var(--red);text-shadow:none;}}
.fup{animation:fup .5s ease-out;} .fdn{animation:fdn .5s ease-out;}
.hora-top{font-family:'JetBrains Mono',monospace;font-size:.52rem;color:var(--muted);flex-shrink:0;text-align:right;line-height:1.6;}

/* ══ B3 STATUS ════════════════════════════════════════════════════════════ */
.b3f{position:fixed;bottom:30px;right:14px;z-index:300;font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:2px;padding:5px 10px;border-radius:4px;display:flex;align-items:center;gap:5px;backdrop-filter:blur(10px);}
.b3-f{color:#f14c60;background:rgba(13,17,23,.96);border:1px solid rgba(241,76,96,.35);}
.b3-a{color:var(--green);background:rgba(13,17,23,.96);border:1px solid rgba(35,209,139,.35);}
.b3r{width:6px;height:6px;border-radius:50%;background:#f14c60;}
.b3g{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 1.5s ease-in-out infinite;}

/* ══ STATUS BAR ═══════════════════════════════════════════════════════════ */
.sbar{position:fixed;bottom:0;left:0;right:0;z-index:200;background:rgba(13,17,23,.97);border-top:1px solid var(--border);padding:0 20px;height:26px;display:flex;align-items:center;gap:14px;}
.sb-item{font-family:'JetBrains Mono',monospace;font-size:.52rem;display:flex;align-items:center;gap:5px;color:var(--muted);}
.sb-dot{width:5px;height:5px;border-radius:50%;}
.sb-ok{background:var(--green);box-shadow:0 0 4px var(--green);}
.sb-err{background:var(--red);}
.sb-warn{background:var(--gold);}
.sb-copy{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:.5rem;color:var(--muted);}

/* ══ MAIN ═════════════════════════════════════════════════════════════════ */
.main{padding:56px 16px 56px;max-width:1700px;margin:0 auto;}

/* ══ IA STRIP ═════════════════════════════════════════════════════════════ */
.ia-strip{background:rgba(35,209,139,.05);border:1px solid rgba(35,209,139,.18);border-left:3px solid var(--green);border-radius:0 5px 5px 0;padding:10px 14px 10px 12px;margin-bottom:10px;display:flex;gap:10px;align-items:flex-start;cursor:pointer;transition:background .15s;}
.ia-strip:hover{background:rgba(35,209,139,.08);}
.ia-badge{font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:700;letter-spacing:2px;color:var(--green);flex-shrink:0;padding:2px 7px;background:rgba(35,209,139,.12);border-radius:3px;margin-top:1px;}
.ia-body{flex:1;min-width:0;}
.ia-txt{font-size:.83rem;color:var(--sub);line-height:1.6;}
.ia-txt.clamp{display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.ia-hint{font-family:'JetBrains Mono',monospace;font-size:.55rem;color:var(--muted);margin-top:4px;}
.ia-aviso{font-size:.62rem;color:var(--muted);margin-top:6px;padding-top:6px;border-top:1px solid rgba(255,255,255,.06);}

/* ══ ÍNDICES ══════════════════════════════════════════════════════════════ */
.idx-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;margin-bottom:10px;}
.ic{background:var(--card);border:1px solid var(--border);border-radius:6px;padding:10px 12px;transition:all .15s;position:relative;overflow:hidden;}
.ic::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--border);}
.ic.iup::before{background:var(--green);}
.ic.idn::before{background:var(--red);}
.ic:hover{background:var(--card2);}
.ic-n{font-size:.55rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:5px;font-weight:500;}
.ic-v{font-family:'JetBrains Mono',monospace;font-size:1rem;font-weight:600;color:var(--text);margin-bottom:3px;}
.ic-c{font-family:'JetBrains Mono',monospace;font-size:.72rem;font-weight:600;}

/* ══ ABAS ═════════════════════════════════════════════════════════════════ */
.tabs{display:flex;border-bottom:1px solid var(--border);margin-bottom:10px;overflow-x:auto;gap:0;}
.tab{font-family:'Barlow Condensed',sans-serif;font-size:.82rem;font-weight:700;letter-spacing:2px;padding:8px 14px;cursor:pointer;color:var(--muted);border-bottom:2px solid transparent;background:none;border-top:none;border-left:none;border-right:none;white-space:nowrap;transition:all .15s;}
.tab:hover{color:var(--sub);}
.tab.active{color:var(--text);border-bottom-color:var(--green);}
.tc{display:none;}
.tc.active{display:block;}

/* ══ REC IA ═══════════════════════════════════════════════════════════════ */
.rec-box{background:rgba(163,113,247,.05);border:1px solid rgba(163,113,247,.2);border-left:3px solid var(--purple);border-radius:0 5px 5px 0;padding:10px 14px 10px 12px;margin-bottom:12px;}
.rec-title{font-family:'Barlow Condensed',sans-serif;font-size:.82rem;font-weight:700;letter-spacing:2px;color:var(--purple);margin-bottom:6px;display:flex;align-items:center;gap:7px;}
.rec-txt{font-size:.8rem;color:var(--sub);line-height:1.7;}
.rec-aviso{font-size:.6rem;color:var(--muted);margin-top:7px;padding-top:7px;border-top:1px solid rgba(255,255,255,.05);}

/* ══ SETORES ══════════════════════════════════════════════════════════════ */
.set-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.sc{background:var(--card);border:1px solid var(--border);border-radius:6px;overflow:hidden;}
.sh{padding:9px 14px;display:flex;align-items:center;justify-content:space-between;}
.sh-n{font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:800;letter-spacing:2px;color:var(--text);}
.sh-m{font-family:'JetBrains Mono',monospace;font-size:.73rem;font-weight:600;}
.sup{background:rgba(35,209,139,.1);border-bottom:2px solid rgba(35,209,139,.25);}
.sdn{background:rgba(241,76,96,.09);border-bottom:2px solid rgba(241,76,96,.22);}
.ar{display:flex;align-items:center;gap:6px;padding:6px 14px;border-bottom:1px solid rgba(255,255,255,.04);font-family:'JetBrains Mono',monospace;font-size:.69rem;}
.ar:last-child{border-bottom:none;}
.ar:hover{background:rgba(255,255,255,.025);}
.at{color:var(--sub);font-weight:600;flex:1;}
.ap{color:var(--muted);font-size:.62rem;min-width:75px;text-align:right;}
.av{font-size:.68rem;font-weight:600;min-width:58px;text-align:right;}
.fav-btn{background:none;border:none;cursor:pointer;font-size:.7rem;opacity:.3;transition:opacity .2s;flex-shrink:0;padding:0 2px;}
.fav-btn.ativo{opacity:1;}

/* ══ TABELA ═══════════════════════════════════════════════════════════════ */
.tb{width:100%;border-collapse:collapse;}
.tb th{font-size:.54rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase;padding:8px 12px;text-align:left;border-bottom:1px solid var(--border);background:var(--bg2);font-weight:500;}
.tb td{font-family:'JetBrains Mono',monospace;font-size:.73rem;padding:9px 12px;border-bottom:1px solid rgba(255,255,255,.04);color:var(--sub);}
.tb tr:hover td{background:var(--card2);}
.tk{color:var(--text);font-weight:600;}
.bm{font-size:.54rem;padding:2px 7px;border-radius:3px;font-weight:600;}
.bm-g{color:var(--green);background:rgba(35,209,139,.1);border:1px solid rgba(35,209,139,.2);}
.bm-y{color:var(--gold);background:rgba(240,180,41,.1);border:1px solid rgba(240,180,41,.2);}

/* ══ CRIPTO ═══════════════════════════════════════════════════════════════ */
.cr-list{display:flex;flex-direction:column;gap:5px;}
.cc{background:var(--card);border:1px solid var(--border);border-radius:6px;padding:11px 16px;display:grid;grid-template-columns:36px 36px 1fr 110px 70px 100px;align-items:center;gap:10px;transition:background .15s;}
.cc:hover{background:var(--card2);}
.cc.dest{border-color:rgba(240,180,41,.35);background:rgba(240,180,41,.03);}
.cc-rank{font-family:'JetBrains Mono',monospace;font-size:.68rem;color:var(--muted);font-weight:600;text-align:center;}
.cc-icon{font-size:1.3rem;text-align:center;}
.cc-info{min-width:0;}
.cc-n{font-size:.9rem;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cc-s{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:var(--muted);}
.cc-price{font-family:'JetBrains Mono',monospace;font-size:.9rem;font-weight:600;color:var(--text);text-align:right;}
.cc-24h{font-family:'JetBrains Mono',monospace;font-size:.72rem;font-weight:600;text-align:right;}
.cc-hist{font-family:'JetBrains Mono',monospace;font-size:.62rem;text-align:right;line-height:1.7;color:var(--muted);}

/* ══ DIVIDENDOS ═══════════════════════════════════════════════════════════ */
.div-info{background:rgba(35,209,139,.05);border:1px solid rgba(35,209,139,.18);border-left:3px solid var(--green);border-radius:0 5px 5px 0;padding:9px 14px 9px 12px;margin-bottom:10px;font-size:.8rem;color:var(--sub);line-height:1.6;}

/* ══ NOTÍCIAS ════════════════════════════════════════════════════════════ */
.nf-bar{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:10px;}
.nf{font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:700;letter-spacing:1px;padding:4px 10px;border-radius:4px;cursor:pointer;border:1px solid var(--border);background:var(--card);color:var(--muted);transition:all .15s;}
.nf:hover{color:var(--sub);border-color:var(--muted);}
.nf.active{font-weight:700;}
.nf[data-cat="Todos"].active  {background:var(--sub);border-color:var(--sub);color:#0d1117;}
.nf[data-cat="Brasil"].active {background:var(--green);border-color:var(--green);color:#0d1117;}
.nf[data-cat="EUA"].active    {background:var(--red);border-color:var(--red);color:#fff;}
.nf[data-cat="China"].active  {background:var(--red);border-color:var(--red);color:#fff;}
.nf[data-cat="Europa"].active {background:var(--blue);border-color:var(--blue);color:#0d1117;}
.nf[data-cat="Guerras"].active{background:var(--orange);border-color:var(--orange);color:#0d1117;}
.nf[data-cat="Cripto"].active {background:var(--gold);border-color:var(--gold);color:#0d1117;}
.nf[data-cat="Mercado"].active{background:var(--purple);border-color:var(--purple);color:#fff;}

.ng{display:grid;grid-template-columns:repeat(2,1fr);gap:6px;}
.nc{border-radius:5px;padding:11px 14px;display:flex;gap:10px;align-items:flex-start;text-decoration:none;border:1px solid rgba(255,255,255,.06);background:var(--card);transition:all .15s;}
.nc:hover{background:var(--card2);border-color:rgba(255,255,255,.1);}
.ntag{font-family:'Barlow Condensed',sans-serif;font-size:.65rem;letter-spacing:1px;padding:2px 7px;border-radius:3px;font-weight:700;white-space:nowrap;flex-shrink:0;margin-top:2px;color:#0d1117;}
.nt-br{background:var(--green);}
.nt-r{background:var(--red);color:#fff;}
.nt-eu{background:var(--blue);}
.nt-gx{background:var(--orange);}
.nt-cr{background:var(--gold);}
.nt-mk{background:var(--purple);color:#fff;}
.nt-title{font-size:.82rem;color:var(--sub);line-height:1.5;font-weight:500;}
.nt-date{font-size:.6rem;color:var(--muted);margin-top:3px;font-family:'JetBrains Mono',monospace;}

/* ══ TICKER ═══════════════════════════════════════════════════════════════ */
.ticker{position:fixed;bottom:26px;left:0;right:0;z-index:100;background:rgba(13,17,23,.97);border-top:1px solid var(--border);padding:0;overflow:hidden;height:28px;display:flex;align-items:center;}
.ticker::before,.ticker::after{content:'';position:absolute;top:0;bottom:0;width:50px;z-index:2;}
.ticker::before{left:0;background:linear-gradient(90deg,rgba(13,17,23,.97),transparent);}
.ticker::after{right:0;background:linear-gradient(-90deg,rgba(13,17,23,.97),transparent);}
.tt-tr{display:inline-flex;animation:scrollt 100s linear infinite;white-space:nowrap;}
@keyframes scrollt{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
.tn{font-family:'JetBrains Mono',monospace;font-size:.58rem;color:var(--sub);padding:0 22px;display:inline-flex;align-items:center;gap:6px;}
.tn-s{color:var(--border);}

/* ══ LOADING ══════════════════════════════════════════════════════════════ */
.loading{position:fixed;inset:0;background:var(--bg);z-index:500;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;}
.ll{font-family:'Barlow Condensed',sans-serif;font-size:2.4rem;font-weight:800;letter-spacing:6px;color:var(--text);}
.lb{width:200px;height:1px;background:var(--border);}
.li{height:100%;background:var(--green);animation:lb 1.8s ease-in-out infinite;}
@keyframes lb{0%{width:0;margin-left:0;}50%{width:100%;}100%{width:0;margin-left:100%;}}
.lm{font-family:'JetBrains Mono',monospace;font-size:.63rem;color:var(--muted);}

@media(max-width:1000px){
  .idx-grid{grid-template-columns:repeat(2,1fr);}
  .set-grid{grid-template-columns:1fr;}
  .ng{grid-template-columns:1fr;}
  .top-idx{display:none;}
  .cc{grid-template-columns:30px 30px 1fr 90px 60px;}
  .cc-hist{display:none;}
}
</style>
</head>
<body>

<div class="loading" id="loading">
  <div class="ll">MARKETPULSE</div>
  <div class="lb"><div class="li"></div></div>
  <div class="lm" id="lmsg">// Conectando ao mercado...</div>
</div>

<!-- TOPBAR -->
<nav class="topbar">
  <a href="/" class="logo"><div class="ld"></div>MARKETPULSE</a>
  <div class="tsep"></div>
  <div class="bb"><span class="bl">BULL</span><span class="vs">VS</span><span class="br">BEAR</span></div>
  <div class="top-idx" id="top-idx">
    <div class="ti"><span class="ti-n">IBOV</span><span id="ti-ibov">—</span></div>
    <div class="ti"><span class="ti-n">USD</span><span id="ti-usd">—</span></div>
    <div class="ti"><span class="ti-n">EUR</span><span id="ti-eur">—</span></div>
    <div class="ti"><span class="ti-n">OURO</span><span id="ti-ouro">—</span></div>
    <div class="ti"><span class="ti-n">PETRÓLEO</span><span id="ti-pet">—</span></div>
    <div class="ti"><span class="ti-n">BTC</span><span id="ti-btc">—</span></div>
    <div class="ti"><span class="ti-n">ETH</span><span id="ti-eth">—</span></div>
  </div>
  <div class="hora-top" id="hora-top">—</div>
</nav>

<!-- B3 -->
<div class="b3f b3-f" id="b3"><div class="b3r" id="b3-dot"></div><span id="b3-lbl">B3 —</span></div>

<!-- MAIN -->
<div class="main">

  <!-- IA RESUMO -->
  <div class="ia-strip" id="ia-strip" onclick="toggleIA()">
    <span class="ia-badge">IA ▸</span>
    <div class="ia-body">
      <div class="ia-txt clamp" id="ia-resumo">Aguardando análise de mercado...</div>
      <div class="ia-hint" id="ia-hint">▼ clique para expandir</div>
      <div class="ia-aviso" id="ia-aviso" style="display:none"></div>
    </div>
  </div>

  <!-- ÍNDICES -->
  <div class="idx-grid" id="idx-grid"></div>

  <!-- ABAS -->
  <div class="tabs">
    <button class="tab active" onclick="showTab('acoes',this)">📈 AÇÕES B3</button>
    <button class="tab" onclick="showTab('fiis',this)">🏢 FIIs</button>
    <button class="tab" onclick="showTab('cripto',this)">₿ CRIPTO</button>
    <button class="tab" onclick="showTab('etfs',this)">📊 ETFs</button>
    <button class="tab" onclick="showTab('divs',this)">💰 DIVIDENDOS</button>
    <button class="tab" onclick="showTab('news',this)">📰 NOTÍCIAS</button>
    <button class="tab" onclick="showTab('favs',this)">⭐ FAVORITOS</button>
  </div>

  <!-- AÇÕES -->
  <div class="tc active" id="tab-acoes">
    <div class="rec-box" id="rec-acoes" style="display:none">
      <div class="rec-title">🤖 IA — Análise de Ações</div>
      <div class="rec-txt" id="rec-acoes-txt"></div>
      <div class="rec-aviso" id="rec-acoes-av"></div>
    </div>
    <div class="set-grid" id="set-grid"></div>
  </div>

  <!-- FIIs -->
  <div class="tc" id="tab-fiis">
    <table class="tb"><thead><tr>
      <th>FII</th><th>Preço</th><th>Dia</th><th>DY Anual</th><th>Freq.</th>
    </tr></thead><tbody id="fiis-tb"></tbody></table>
  </div>

  <!-- CRIPTO -->
  <div class="tc" id="tab-cripto">
    <div class="rec-box" id="rec-cripto" style="display:none">
      <div class="rec-title">🤖 IA — Análise de Criptos</div>
      <div class="rec-txt" id="rec-cripto-txt"></div>
      <div class="rec-aviso" id="rec-cripto-av"></div>
    </div>
    <div class="cr-list" id="cr-list"></div>
  </div>

  <!-- ETFs -->
  <div class="tc" id="tab-etfs">
    <div class="rec-box" id="rec-etfs" style="display:none">
      <div class="rec-title">🤖 IA — Análise de ETFs</div>
      <div class="rec-txt" id="rec-etfs-txt"></div>
      <div class="rec-aviso" id="rec-etfs-av"></div>
    </div>
    <table class="tb"><thead><tr>
      <th>ETF</th><th>Preço</th><th>Dia</th>
    </tr></thead><tbody id="etfs-tb"></tbody></table>
  </div>

  <!-- DIVIDENDOS -->
  <div class="tc" id="tab-divs">
    <div class="div-info">
      🤖 <b style="color:var(--green)">IA recomenda</b> FIIs com melhor relação risco/retorno pelo DY mensal.
      <b style="color:var(--gold)">EX-DATA</b>: você precisa ter a cota ANTES dessa data para receber o dividendo.
      ⚠️ Valores são estimativas baseadas nos últimos pagamentos históricos.
    </div>
    <table class="tb"><thead><tr>
      <th>FII</th><th>Valor/Cota</th><th>Ex-Data</th><th>Pagamento</th><th>DY Mês</th><th>Avaliação IA</th>
    </tr></thead><tbody id="divs-tb"></tbody></table>
  </div>

  <!-- NOTÍCIAS -->
  <div class="tc" id="tab-news">
    <div class="nf-bar">
      <button class="nf active" data-cat="Todos"   onclick="filtNews('Todos',this)">🌐 TODOS</button>
      <button class="nf" data-cat="Brasil"  onclick="filtNews('Brasil',this)">🇧🇷 BRASIL</button>
      <button class="nf" data-cat="EUA"     onclick="filtNews('EUA',this)">🇺🇸 EUA</button>
      <button class="nf" data-cat="China"   onclick="filtNews('China',this)">🇨🇳 CHINA</button>
      <button class="nf" data-cat="Europa"  onclick="filtNews('Europa',this)">🇪🇺 EUROPA</button>
      <button class="nf" data-cat="Guerras" onclick="filtNews('Guerras',this)">⚔️ GUERRAS</button>
      <button class="nf" data-cat="Cripto"  onclick="filtNews('Cripto',this)">₿ CRIPTO</button>
      <button class="nf" data-cat="Mercado" onclick="filtNews('Mercado',this)">📈 MERCADO</button>
    </div>
    <div class="ng" id="news-grid"></div>
  </div>

  <!-- FAVORITOS -->
  <div class="tc" id="tab-favs">
    <p style="color:var(--muted);font-size:.8rem;margin-bottom:10px">⭐ Clique na estrela de qualquer ação para favoritar. Salvo no seu navegador.</p>
    <div class="set-grid" id="favs-grid"></div>
    <div id="favs-empty" style="color:var(--muted);font-size:.78rem;padding:20px;display:none">Nenhum favorito ainda. Clique na estrela de uma ação.</div>
  </div>
</div>

<!-- TICKER -->
<div class="ticker"><div class="tt-tr" id="tt-tr"><span class="tn">Carregando...</span></div></div>

<!-- STATUS BAR -->
<div class="sbar">
  <div class="sb-item"><div class="sb-dot sb-warn" id="st-gf"></div><span>Google Finance</span></div>
  <div class="sb-item"><div class="sb-dot sb-warn" id="st-cg"></div><span>CoinGecko</span></div>
  <div class="sb-item"><div class="sb-dot sb-warn" id="st-groq"></div><span>Groq IA</span></div>
  <div class="sb-item" id="prox-item" style="margin-left:8px;font-size:.5rem;color:var(--muted)">próx: —</div>
  <div class="sb-copy">© 2026 Guilherme Lima · MarketPulse · Todos os direitos reservados</div>
</div>

<script>
const $ = id => document.getElementById(id);
const cls = v => parseFloat(v||0) >= 0 ? 'up' : 'down';

let _news = [];
let _newsCat = 'Todos';   // CORREÇÃO: mantém categoria selecionada entre atualizações
let _acoes_data = {};
let _favs = JSON.parse(localStorage.getItem('mp_favs')||'[]');
let _iaExp = false;
let _proxAt = 60, _proxTmr = null;

const CAT_CFG = {
  Brasil: {tag:'nt-br', lbl:'🇧🇷 BRASIL'},
  EUA:    {tag:'nt-r',  lbl:'🇺🇸 EUA'},
  China:  {tag:'nt-r',  lbl:'🇨🇳 CHINA'},
  Europa: {tag:'nt-eu', lbl:'🇪🇺 EUROPA'},
  Guerras:{tag:'nt-gx', lbl:'⚔️ GUERRAS'},
  Cripto: {tag:'nt-cr', lbl:'₿ CRIPTO'},
  Mercado:{tag:'nt-mk', lbl:'📈 MERCADO'},
};
const CAT_C = {Brasil:'#23d18b',EUA:'#f14c60',China:'#f14c60',Europa:'#58a6ff',Guerras:'#f78166',Cripto:'#f0b429',Mercado:'#a371f7'};

// Ícones das criptos
const CRIPTO_ICON = {
  BTC:'₿', ETH:'Ξ', BNB:'⬡', SOL:'◎', XRP:'✕',
  ADA:'₳', AVAX:'🔺', DOGE:'🐶', DOT:'●', LINK:'🔗',
};

function fp(v){
  if(!v&&v!==0) return '—';
  if(v>=1000) return v.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});
  return v.toFixed(2).replace('.',',');
}

function setVal(id,txt,c,flash){
  const el=$(id); if(!el) return;
  const old=el.textContent;
  el.textContent=txt;
  if(c) el.className=c;
  if(flash&&old&&old!==txt&&old!=='—'){
    el.classList.remove('fup','fdn');
    void el.offsetWidth;
    el.classList.add(c==='up'?'fup':'fdn');
  }
}

// ── IA ───────────────────────────────────────────────────────────────────
function toggleIA(){
  _iaExp = !_iaExp;
  const txt=$('ia-resumo'), hint=$('ia-hint'), av=$('ia-aviso');
  if(_iaExp){
    txt.classList.remove('clamp');
    hint.textContent='▲ clique para recolher';
    if(av) av.style.display='block';
  } else {
    txt.classList.add('clamp');
    hint.textContent='▼ clique para expandir';
    if(av) av.style.display='none';
  }
}

// Mercado fechado: IA começa expandida automaticamente
function setIAMode(aberto){
  const txt=$('ia-resumo'), hint=$('ia-hint'), av=$('ia-aviso');
  if(!aberto && !_iaExp){
    // Mercado fechado: expande automaticamente
    _iaExp=true;
    txt.classList.remove('clamp');
    hint.textContent='▲ clique para recolher';
    if(av) av.style.display='block';
  }
}

// ── Abas ─────────────────────────────────────────────────────────────────
function showTab(nome,btn){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tc').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  $('tab-'+nome).classList.add('active');
}

// ── Favoritos ─────────────────────────────────────────────────────────────
function toggleFav(ticker){
  const i=_favs.indexOf(ticker);
  if(i>=0) _favs.splice(i,1); else _favs.push(ticker);
  localStorage.setItem('mp_favs',JSON.stringify(_favs));
  renderFavs();
  document.querySelectorAll(`.fav-btn[data-ticker="${ticker}"]`).forEach(b=>{
    b.textContent=_favs.includes(ticker)?'⭐':'☆';
    b.classList.toggle('ativo',_favs.includes(ticker));
  });
}

function renderFavs(){
  const grid=$('favs-grid'), empty=$('favs-empty');
  const items=[];
  for(const [s,l] of Object.entries(_acoes_data))
    for(const a of l) if(_favs.includes(a.ticker)) items.push({...a,setor:s});
  if(!items.length){grid.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  grid.innerHTML=items.map(a=>`<div class="sc">
    <div class="sh ${a.var_dia>=0?'sup':'sdn'}">
      <span class="sh-n">${a.ticker}</span>
      <span class="sh-m ${cls(a.var_dia)}">${a.var_dia_fmt}</span>
    </div>
    <div class="ar">
      <span class="at">${a.setor}</span>
      <span class="ap">R$${a.preco_fmt}</span>
      <span class="av ${cls(a.var_dia)}">${a.var_dia_fmt}</span>
    </div>
  </div>`).join('');
}

// ── Índices ───────────────────────────────────────────────────────────────
function renderIdx(d){
  const order=['Ibovespa','Dólar/Real','Euro/Real','Ouro','Petróleo','S&P 500','Nasdaq'];
  $('idx-grid').innerHTML=order.map(n=>{
    const i=d[n]; if(!i) return '';
    const uc=parseFloat(i.var_dia||0)>=0?'iup':'idn';
    return `<div class="ic ${uc}">
      <div class="ic-n">${n}</div>
      <div class="ic-v">${i.preco_fmt||'—'}</div>
      <div class="ic-c ${cls(i.var_dia)}">${i.var_dia_fmt}</div>
    </div>`;
  }).join('');
  [['Ibovespa','ti-ibov'],['Dólar/Real','ti-usd'],['Euro/Real','ti-eur'],['Ouro','ti-ouro'],['Petróleo','ti-pet']]
    .forEach(([n,id])=>{ const i=d[n]; if(i) setVal(id,i.var_dia_fmt,cls(i.var_dia),true); });
}

// ── Ações ─────────────────────────────────────────────────────────────────
function renderAcoes(a){
  _acoes_data=a;
  $('set-grid').innerHTML=Object.entries(a).map(([s,l])=>{
    if(!l.length) return '';
    const med=l.reduce((x,a)=>x+a.var_dia,0)/l.length;
    return `<div class="sc">
      <div class="sh ${med>=0?'sup':'sdn'}">
        <span class="sh-n">${s}</span>
        <span class="sh-m ${cls(med)}">${med>=0?'+':''}${med.toFixed(2)}%</span>
      </div>
      ${l.map(a=>`<div class="ar">
        <button class="fav-btn ${_favs.includes(a.ticker)?'ativo':''}" data-ticker="${a.ticker}" onclick="toggleFav('${a.ticker}')">${_favs.includes(a.ticker)?'⭐':'☆'}</button>
        <span class="at">${a.ticker}</span>
        <span class="ap">R$${a.preco_fmt||'—'}</span>
        <span class="av ${cls(a.var_dia)}">${a.var_dia_fmt}</span>
      </div>`).join('')}
    </div>`;
  }).join('');
  renderFavs();
}

// ── FIIs ──────────────────────────────────────────────────────────────────
function renderFiis(f){
  $('fiis-tb').innerHTML=f.map(x=>`<tr>
    <td class="tk">${x.ticker}</td>
    <td>R$${x.preco_fmt||'—'}</td>
    <td class="${cls(x.var_dia)}">${x.var_dia_fmt}</td>
    <td>${x.dy||'—'}</td>
    <td><span class="bm bm-g">${x.freq||'Mensal'}</span></td>
  </tr>`).join('');
}

// ── ETFs ──────────────────────────────────────────────────────────────────
function renderEtfs(e){
  $('etfs-tb').innerHTML=e.map(x=>`<tr>
    <td class="tk">${x.ticker}</td>
    <td>R$${x.preco_fmt||'—'}</td>
    <td class="${cls(x.var_dia)}">${x.var_dia_fmt}</td>
  </tr>`).join('');
}

// ── Cripto ────────────────────────────────────────────────────────────────
function renderCrypto(cs){
  $('cr-list').innerHTML=cs.map((c,i)=>{
    const icon=CRIPTO_ICON[c.simbolo]||'●';
    return `<div class="cc ${c.destaque?'dest':''}">
      <div class="cc-rank">#${i+1}</div>
      <div class="cc-icon">${icon}</div>
      <div class="cc-info">
        <div class="cc-n">${c.nome}${c.destaque?' 🔥':''}</div>
        <div class="cc-s">${c.simbolo}</div>
      </div>
      <div class="cc-price">$${fp(c.preco)}</div>
      <div class="cc-24h ${cls(c.var_dia)}">${c.var_dia_fmt}<br><span style="font-size:.55rem;opacity:.6">24h</span></div>
      <div class="cc-hist">
        <span style="color:var(--muted)">7d </span><span class="${cls(c.var_sem)}">${c.var_sem_fmt}</span><br>
        <span style="color:var(--muted)">30d </span><span class="${cls(c.var_mes)}">${c.var_mes_fmt}</span>
      </div>
    </div>`;
  }).join('');
  const btc=cs.find(c=>c.simbolo==='BTC'), eth=cs.find(c=>c.simbolo==='ETH');
  if(btc) setVal('ti-btc',btc.var_dia_fmt,cls(btc.var_dia),true);
  if(eth) setVal('ti-eth',eth.var_dia_fmt,cls(eth.var_dia),true);
}

// ── Dividendos ────────────────────────────────────────────────────────────
function renderDivs(ds){
  const col={"✅ Recomendado":"color:var(--green)","⚠️ Neutro":"color:var(--gold)","❌ Evitar":"color:var(--red)"};
  $('divs-tb').innerHTML=ds.map(d=>`<tr>
    <td class="tk">${d.ticker}</td>
    <td style="color:var(--text);font-weight:600">${d.valor}</td>
    <td style="color:var(--gold)">${d.ex_data}</td>
    <td>${d.pgto}</td>
    <td class="up">${d.dy_mes}</td>
    <td style="${col[d.ia]||''};font-weight:600;font-size:.72rem">${d.ia}</td>
  </tr>`).join('');
}

// ── Notícias — CORREÇÃO: filtro mantido entre atualizações ────────────────
function _newsHTML(lista){
  return lista.map(n=>{
    const c=CAT_CFG[n.categoria]||{tag:'nt-mk',lbl:n.categoria};
    return `<a class="nc" href="${n.link}" target="_blank" rel="noopener">
      <span class="ntag ${c.tag}">${c.lbl}</span>
      <div>
        <div class="nt-title">${n.titulo}</div>
        <div class="nt-date">${n.data}</div>
      </div>
    </a>`;
  }).join('');
}

function filtNews(cat,btn){
  document.querySelectorAll('.nf').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  _newsCat=cat;   // salva categoria selecionada
  const lista=cat==='Todos' ? _news : _news.filter(n=>n.categoria===cat);
  $('news-grid').innerHTML=lista.length ? _newsHTML(lista) : '<div style="color:var(--muted);padding:20px;font-size:.8rem">Nenhuma notícia nessa categoria nas últimas 24h.</div>';
}

function renderNews(ns){
  _news=ns;
  // Re-aplica o filtro atual — não reseta para Todos na auto-atualização
  const lista=_newsCat==='Todos' ? _news : _news.filter(n=>n.categoria===_newsCat);
  $('news-grid').innerHTML=lista.length ? _newsHTML(lista) : '<div style="color:var(--muted);padding:20px;font-size:.8rem">Nenhuma notícia nessa categoria nas últimas 24h.</div>';

  // Ticker: Guerras e EUA primeiro, notícias mais impactantes
  const ord=['Guerras','EUA','China','Europa','Brasil','Cripto','Mercado'];
  const sorted=[...ns].sort((a,b)=>ord.indexOf(a.categoria)-ord.indexOf(b.categoria));
  const items=sorted.slice(0,18).map(n=>{
    const c=CAT_CFG[n.categoria]||{lbl:n.categoria};
    return `<span class="tn"><span style="font-weight:700;color:${CAT_C[n.categoria]||'#cdd9e5'}">${c.lbl}</span> ${n.titulo} <span class="tn-s">///</span></span>`;
  }).join('');
  $('tt-tr').innerHTML=items+items;
}

// ── Recomendações ─────────────────────────────────────────────────────────
function renderRec(boxId,txtId,avId,rec){
  if(!rec?.texto||rec.texto==='—') return;
  $(boxId).style.display='block';
  $(txtId).textContent=rec.texto;
  if(avId&&rec.aviso) $(avId).textContent=rec.aviso;
}

// ── B3 ────────────────────────────────────────────────────────────────────
function renderB3(b3){
  const el=$('b3'),dot=$('b3-dot'),lbl=$('b3-lbl');
  if(b3.aberta){
    el.className='b3f b3-a'; dot.className='b3g';
    lbl.textContent=`B3 ABERTA · ${b3.hora}`;
  } else {
    el.className='b3f b3-f'; dot.className='b3r';
    lbl.textContent=`B3 FECHADA · ${b3.hora}`;
  }
}

// ── Status ────────────────────────────────────────────────────────────────
function renderStatus(st){
  if(!st) return;
  const dot=(id,ok)=>{const e=$(id);if(e) e.className='sb-dot '+(ok?'sb-ok':'sb-err');};
  dot('st-gf',   (st.google||'').startsWith('ok'));
  dot('st-cg',   (st.coingecko||'').startsWith('ok'));
  dot('st-groq', st.groq==='ok'||(st.groq||'').startsWith('ok'));
}

// ── Timer ─────────────────────────────────────────────────────────────────
function startTimer(s){
  clearInterval(_proxTmr);
  _proxAt=s;
  _proxTmr=setInterval(()=>{
    _proxAt=Math.max(0,_proxAt-1);
    const e=$('prox-item');
    if(e) e.textContent=`próx: ${_proxAt}s`;
  },1000);
}

// ── Busca ─────────────────────────────────────────────────────────────────
async function buscar(){
  try{
    const r=await fetch('/api/dados');
    if(r.status===202){
      const j=await r.json();
      $('lmsg').textContent='// '+(j.msg||'Coletando...');
      setTimeout(buscar,5000);
      return;
    }
    const res=await r.json();
    if(!res.ok) throw new Error(res.erro||'erro');
    const d=res.dados;

    renderB3(d.b3);
    setIAMode(d.b3.aberta);
    renderIdx(d.indices);
    renderAcoes(d.acoes);
    renderFiis(d.fiis);
    renderEtfs(d.etfs);
    renderCrypto(d.cryptos);
    renderNews(d.noticias);
    if(d.dividendos?.length) renderDivs(d.dividendos);
    renderRec('rec-acoes','rec-acoes-txt','rec-acoes-av',d.rec_acoes);
    renderRec('rec-cripto','rec-cripto-txt','rec-cripto-av',d.rec_cryptos);
    renderRec('rec-etfs','rec-etfs-txt','rec-etfs-av',d.rec_etfs);
    renderStatus(d.api_status);

    // IA resumo
    if(d.resumo_ia){
      const partes=d.resumo_ia.split('\n\n⚠️');
      const txt=$('ia-resumo'), av=$('ia-aviso');
      if(txt) txt.textContent=partes[0]||'';
      if(av)  av.textContent=partes[1]?'⚠️'+partes[1]:'';
    }

    $('hora-top').innerHTML=`Atualizado ${d.atualizado}<br>${d.b3.data}`;
    $('loading').style.display='none';
    startTimer(60);

  }catch(e){
    $('lmsg').textContent='// Erro: '+e.message;
    console.error(e);
  }
}

buscar();
setInterval(buscar,60000);
</script>
</body>
</html>
